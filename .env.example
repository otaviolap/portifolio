# =============================================================================
# Variáveis de ambiente — copie para .env.local e preencha.
# NUNCA commite .env.local (já está no .gitignore).
# =============================================================================

# --- Banco de dados (Neon) --------------------------------------------------
# Crie um projeto em https://neon.tech e pegue as duas connection strings.
# DATABASE_URL: a POOLED (tem "-pooler" no host). Use pgbouncer + connect_timeout.
#   Serverless não reusa conexão; sem o pooler você esgota o limite da Neon num pico.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"

# DIRECT_URL: a DIRETA (sem "-pooler"). Usada só por `prisma migrate` e introspect.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Auth -------------------------------------------------------------------
# Segredo do JWT de sessão. Gere com:  openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio-de-32-bytes"

# Salt para hash de IP dos leads (LGPD: guardamos SHA-256(ip+salt), nunca o IP cru).
# Gere com:  openssl rand -hex 16
IP_HASH_SALT="troque-por-um-salt-aleatorio"

# Credenciais do admin — usadas SÓ pelo seed (prisma/seed.ts) para criar o usuário.
# Depois de rodar o seed uma vez, pode remover ADMIN_PASSWORD daqui.
ADMIN_EMAIL="seu-email@exemplo.com"
ADMIN_PASSWORD="uma-senha-forte-so-para-o-seed"

# --- Vercel Blob (upload de imagens) ----------------------------------------
# No painel da Vercel: Storage > Blob > crie um store > copie o token RW.
# Em produção a Vercel injeta isso sozinho; localmente você precisa colar aqui.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
